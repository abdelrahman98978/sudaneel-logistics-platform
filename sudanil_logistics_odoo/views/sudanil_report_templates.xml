<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Register QWeb PDF Report Action -->
    <record id="action_report_sudanil_waybill" model="ir.actions.report">
        <field name="name">Sovereign Waybill (بوليصة الشحن السيادية)</field>
        <field name="model">sudanil.shipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sudanil_logistics_odoo.report_waybill_template</field>
        <field name="report_file">sudanil_logistics_odoo.report_waybill_template</field>
        <field name="binding_model_id" ref="model_sudanil_shipment"/>
        <field name="binding_type">report</field>
    </record>

    <!-- QWeb HTML/PDF Template -->
    <template id="report_waybill_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <!-- Styles for Executive Sovereign Visual Identity (Navy & Gold Accent) -->
                    <style type="text/css">
                        @font-face {
                            font-family: 'Cairo';
                            src: local('Cairo');
                        }
                        .sudanil-container {
                            font-family: 'Cairo', 'Helvetica Neue', sans-serif;
                            color: #021e2d;
                            direction: ltr;
                        }
                        .sudanil-rtl {
                            direction: rtl;
                            text-align: right;
                        }
                        .sudanil-header {
                            border-bottom: 2px solid #795900;
                            padding-bottom: 15px;
                            margin-bottom: 25px;
                        }
                        .sudanil-title {
                            font-size: 28px;
                            font-weight: 800;
                            color: #021e2d;
                            text-align: center;
                            letter-spacing: 2px;
                        }
                        .sudanil-subtitle {
                            font-size: 14px;
                            color: #795900;
                            text-align: center;
                            font-weight: 700;
                            margin-top: -2px;
                            text-transform: uppercase;
                        }
                        .sovereign-badge {
                            background-color: #021e2d;
                            color: #ffffff;
                            font-weight: bold;
                            padding: 6px 12px;
                            border-radius: 2px;
                            display: inline-block;
                            border-left: 4px solid #795900;
                        }
                        .sudanil-grid {
                            width: 100%;
                            border-collapse: collapse;
                            margin-top: 25px;
                        }
                        .sudanil-grid th {
                            background-color: #f8fafc;
                            color: #021e2d;
                            border: 1px solid #e2e8f0;
                            padding: 12px;
                            font-size: 10px;
                            text-transform: uppercase;
                            letter-spacing: 1px;
                        }
                        .sudanil-grid td {
                            border: 1px solid #e2e8f0;
                            padding: 12px;
                            font-size: 11px;
                            vertical-align: top;
                        }
                        .premium-border {
                            border: 1px solid #795900 !important;
                        }
                        .watermark {
                            position: absolute;
                            top: 45%;
                            left: 20%;
                            transform: rotate(-45deg);
                            font-size: 80px;
                            color: rgba(2, 30, 45, 0.03);
                            font-weight: 900;
                            z-index: -1;
                            text-transform: uppercase;
                        }
                        .signature-line {
                            border-top: 1px solid #021e2d;
                            margin-top: 40px;
                            padding-top: 5px;
                            font-size: 10px;
                            font-weight: bold;
                        }
                    </style>

                    <div class="page sudanil-container">
                        <div class="watermark">SOVEREIGN CARGO</div>
                        
                        <!-- Header -->
                        <div class="sudanil-header">
                            <div class="row items-center">
                                <div class="col-4">
                                    <img src="/sudanil_logistics_odoo/static/description/icon.png" style="max-height: 80px;"/>
                                </div>
                                <div class="col-4 text-center">
                                    <h2 class="sudanil-title">WAYBILL</h2>
                                    <div class="sudanil-subtitle">Sudanil Logistics Sovereign Group</div>
                                </div>
                                <div class="col-4 text-right sudanil-rtl">
                                    <h2 class="sudanil-title" style="font-family: 'Cairo';">بوليصة شحن</h2>
                                    <div class="sudanil-subtitle" style="font-family: 'Cairo';">مجموعة سودانيل اللوجستية السيادية</div>
                                </div>
                            </div>
                        </div>

                        <!-- Core Tracking Data -->
                        <div class="row">
                            <div class="col-6">
                                <div class="mb-2"><strong>Ref No:</strong> <span class="sovereign-badge" t-field="o.name"/></div>
                                <div><strong>Client:</strong> <span t-field="o.partner_id.name"/></div>
                                <div><strong>Cargo:</strong> <span t-field="o.cargo_type"/></div>
                            </div>
                            <div class="col-6 text-right sudanil-rtl">
                                <div class="mb-2"><strong>رقم المرجع:</strong> <span class="sovereign-badge" t-field="o.name"/></div>
                                <div><strong>العميل:</strong> <span t-field="o.partner_id.name"/></div>
                                <div><strong>البضاعة:</strong> <span t-field="o.cargo_type"/></div>
                            </div>
                        </div>

                        <!-- Routing Table -->
                        <table class="sudanil-grid mt-4">
                            <thead>
                                <tr>
                                    <th>Logistics Route (خط السير اللوجستي)</th>
                                    <th>Cargo Metrics (مقاييس الشحنة)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <div class="row">
                                            <div class="col-6"><strong>Origin:</strong></div>
                                            <div class="col-6 text-right"><span t-field="o.origin_id.name"/></div>
                                        </div>
                                        <div class="row mt-2">
                                            <div class="col-6"><strong>Destination:</strong></div>
                                            <div class="col-6 text-right"><span t-field="o.destination_id.name"/></div>
                                        </div>
                                        <div class="row mt-2">
                                            <div class="col-6"><strong>Method:</strong></div>
                                            <div class="col-6 text-right"><span t-field="o.route_type"/></div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="row">
                                            <div class="col-6"><strong>Gross Weight:</strong></div>
                                            <div class="col-6 text-right"><span t-field="o.cargo_weight"/> Tons</div>
                                        </div>
                                        <div class="row mt-2">
                                            <div class="col-6"><strong>Customs Stage:</strong></div>
                                            <div class="col-6 text-right"><span t-field="o.customs_status"/></div>
                                        </div>
                                        <div class="row mt-2">
                                            <div class="col-6"><strong>Declaration:</strong></div>
                                            <div class="col-6 text-right"><span t-field="o.customs_declaration_no"/></div>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Milestone History -->
                        <h4 class="mt-4 mb-2 text-primary" style="font-size: 14px; font-weight: bold; border-left: 3px solid #795900; padding-left: 10px;">Tracking Milestone History (سجل تتبع المراحل)</h4>
                        <table class="sudanil-grid">
                            <thead>
                                <tr>
                                    <th style="width: 25%;">Timestamp (الوقت)</th>
                                    <th style="width: 25%;">Terminal (المحطة)</th>
                                    <th style="width: 50%;">Operation Details (تفاصيل العملية)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.history_ids" t-as="h">
                                    <tr>
                                        <td><span t-field="h.timestamp"/></td>
                                        <td><span t-field="h.location_id.name"/></td>
                                        <td><span t-field="h.description"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Legal Footer -->
                        <div class="mt-5 p-3" style="background-color: #f8fafc; border-top: 2px solid #021e2d;">
                            <div class="row">
                                <div class="col-8">
                                    <p style="font-size: 9px; line-height: 1.4; color: #475569;">
                                        This document is an electronically generated sovereign waybill. It serves as official proof of cargo transit status and customs declaration validity within the Sudanil Logistics Integrated Network. Tampering with this document is subject to legal action under sovereign maritime and land freight regulations.
                                    </p>
                                </div>
                                <div class="col-4 text-right sudanil-rtl">
                                    <p style="font-size: 9px; line-height: 1.4; color: #475569; font-family: 'Cairo';">
                                        تعد هذه الوثيقة بوليصة شحن سيادية صادرة إلكترونياً. تُعتبر دليلاً رسمياً على حالة ترانزيت الشحنة وصلاحية البيان الجمركي ضمن شبكة سودانيل اللوجستية الموحدة. أي تلاعب في هذه الوثيقة يعرض صاحبه للمساءلة القانونية.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-5">
                            <div class="col-5">
                                <div class="signature-line">Terminal Operations Manager</div>
                            </div>
                            <div class="col-2"></div>
                            <div class="col-5 text-right sudanil-rtl">
                                <div class="signature-line" style="font-family: 'Cairo';">مدير عمليات المحطة اللوجستية</div>
                            </div>
                        </div>
                    </div>

                </t>
            </t>
        </t>
    </template>
</odoo>
