<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Dashboard Main View -->
    <record id="view_sudanil_dashboard" model="ir.ui.view">
        <field name="name">sudanil.dashboard</field>
        <field name="model">sudanil.dashboard</field>
        <field name="arch" type="xml">
            <dashboard>
                <view type="form">
                    <sheet>
                        <div class="o_dashboard_main">
                            <!-- Executive Summary Cards -->
                            <div class="row">
                                <div class="col-lg-3 col-md-6 mb-4">
                                    <div class="card bg-info text-white">
                                        <div class="card-body">
                                            <h5 class="card-title">Active Shipments</h5>
                                            <h2 class="card-text" t-esc="dashobard_data['total_active_shipments']">0</h2>
                                            <small>Currently in transit or processing</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6 mb-4">
                                    <div class="card bg-success text-white">
                                        <div class="card-body">
                                            <h5 class="card-title">Total Customers</h5>
                                            <h2 class="card-text" t-esc="dashboard_data['total_customers']">0</h2>
                                            <small><t t-esc="dashboard_data['active_customers']"/> Active</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6 mb-4">
                                    <div class="card bg-warning text-white">
                                        <div class="card-body">
                                            <h5 class="card-title">Open Opportunities</h5>
                                            <h2 class="card-text" t-esc="dashboard_data['open_opportunities']">0</h2>
                                            <small>Value: <t t-esc="dashboard_data.get('total_opportunity_value', 0)"/></small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6 mb-4">
                                    <div class="card bg-danger text-white">
                                        <div class="card-body">
                                            <h5 class="card-title">Overdue Payments</h5>
                                            <h2 class="card-text" t-esc="dashboard_data['overdue_payments']">0 SDG</h2>
                                            <small>Pending: <t t-esc="dashboard_data['pending_payments']"/> SDG</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Revenue Section -->
                            <div class="row mt-4">
                                <div class="col-lg-6">
                                    <div class="card">
                                        <div class="card-header bg-primary text-white">
                                            <h5>Revenue Overview</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <h6>This Month</h6>
                                                    <h4 t-esc="dashboard_data['revenue_this_month']">0 SDG</h4>
                                                </div>
                                                <div class="col-md-6">
                                                    <h6>This Year</h6>
                                                    <h4 t-esc="dashboard_data['revenue_this_year']">0 SDG</h4>
                                                </div>
                                            </div>
                                            <div class="mt-3">
                                                <div class="progress">
                                                    <div class="progress-bar bg-success" role="progressbar" style="width: 75%;" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">Collected 75%</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Warehouse Occupancy -->
                                <div class="col-lg-6">
                                    <div class="card">
                                        <div class="card-header bg-info text-white">
                                            <h5>Warehouse Status</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label>Average Occupancy</label>
                                                <div class="progress" style="height: 25px;">
                                                    <div class="progress-bar" role="progressbar" t-att-style="'width: ' + str(dashboard_data['warehouse_occupancy']) + '%'" t-att-aria-valuenow="dashboard_data['warehouse_occupancy']" aria-valuemin="0" aria-valuemax="100">
                                                        <t t-esc="dashboard_data['warehouse_occupancy']"/>%
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <label>Customs Clearance Rate</label>
                                                <div class="progress" style="height: 25px;">
                                                    <div class="progress-bar bg-success" role="progressbar" t-att-style="'width: ' + str(dashboard_data['customs_clearance_rate']) + '%'" t-att-aria-valuenow="dashboard_data['customs_clearance_rate']" aria-valuemin="0" aria-valuemax="100">
                                                        <t t-esc="dashboard_data['customs_clearance_rate']"/>%
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- KPIs Section -->
                            <div class="row mt-4">
                                <div class="col-lg-4">
                                    <div class="card">
                                        <div class="card-header">
                                            <h6>Avg Shipment Time</h6>
                                        </div>
                                        <div class="card-body text-center">
                                            <h2><t t-esc="dashboard_data.get('average_shipment_time', 0)"/> days</h2>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="card">
                                        <div class="card-header">
                                            <h6>On-Time Delivery Rate</h6>
                                        </div>
                                        <div class="card-body text-center">
                                            <h2><t t-esc="dashboard_data.get('on_time_delivery_rate', 0)"/>%</h2>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="card">
                                        <div class="card-header">
                                            <h6>Customer Satisfaction</h6>
                                        </div>
                                        <div class="card-body text-center">
                                            <h2><t t-esc="dashboard_data.get('customer_satisfaction', 0)"/>/100</h2>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Top Performers -->
                            <div class="row mt-4">
                                <div class="col-lg-6">
                                    <div class="card">
                                        <div class="card-header bg-success text-white">
                                            <h5>Top Customer</h5>
                                        </div>
                                        <div class="card-body">
                                            <h4><t t-esc="dashboard_data.get('top_customer', 'N/A')"/></h4>
                                            <p>Lifetime Value: <t t-esc="dashboard_data.get('top_customer_value', 0)"/> SDG</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="card">
                                        <div class="card-header bg-primary text-white">
                                            <h5>Top Sales Representative</h5>
                                        </div>
                                        <div class="card-body">
                                            <h4><t t-esc="dashboard_data.get('top_sales_rep', 'N/A')"/></h4>
                                            <p>Opportunity Value: <t t-esc="dashboard_data.get('top_sales_rep_value', 0)"/> SDG</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </sheet>
                </view>
            </dashboard>
        </field>
    </record>

    <!-- Action for Dashboard -->
    <record id="action_sudanil_dashboard" model="ir.actions.act_window">
        <field name="name">Executive Dashboard</field>
        <field name="res_model">sudanil.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="help" type="html">
            <p>Executive summary of Sudanil Logistics operations and performance metrics.</p>
        </field>
    </record>

    <!-- Dashboard Menu -->
    <menuitem id="menu_sudanil_dashboard" name="Dashboard" parent="menu_sudanil_root" action="action_sudanil_dashboard" sequence="1" web_icon="sudanil_logistics_odoo,static/description/icon.png"/>

</odoo>
